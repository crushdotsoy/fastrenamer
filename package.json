{
  "name": "fast-renamer",
  "version": "0.1.5",
  "description": "Desktop batch renaming utility built with Bun, Electron, React, and TypeScript.",
  "author": "crushdotsoy",
  "type": "module",
  "workspaces": ["packages/*"],
  "main": "dist-electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron:dev": "bun run dev",
    "start": "electron .",
    "build": "tsc -b && vite build",
    "electron:build": "bun run build && electron-builder --publish never",
    "electron:build:mac": "bun run build && electron-builder --mac --publish never",
    "electron:build:win": "bun run build && electron-builder --win --publish never",
    "electron:build:linux": "bun run build && electron-builder --linux --publish never",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.fast-renamer.app",
    "productName": "Fast Renamer",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "crushdotsoy",
        "repo": "fastrenamer"
      }
    ],
    "files": [
      "dist-renderer/**",
      "dist-electron/**",
      "electron/preload.cjs",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Fast-Renamer-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Fast-Renamer-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "artifactName": "Fast-Renamer-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fast-renamer/rename-engine": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.552.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "vite-plugin-electron": "^0.29.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^38.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.3.10"
}
