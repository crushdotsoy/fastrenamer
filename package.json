{
  "name": "fast-renamer",
  "version": "0.2.6",
  "description": "Desktop batch renaming utility built with Bun, Electron, React, and TypeScript.",
  "author": "crushdotsoy",
  "type": "module",
  "workspaces": ["packages/*"],
  "main": "dist-electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "electron:dev": "bun run dev",
    "start": "electron .",
    "build": "tsc -b && vite build",
    "electron:build": "bun run build && electron-builder --publish never",
    "electron:build:mac": "bun run build && electron-builder --mac --publish never",
    "electron:build:win": "bun run build && electron-builder --win --publish never",
    "electron:build:linux": "bun run build && electron-builder --linux --publish never",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.fast-renamer.app",
    "productName": "Fast Renamer",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "crushdotsoy",
        "repo": "fastrenamer"
      }
    ],
    "files": [
      "dist-renderer/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Fast-Renamer-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Fast-Renamer-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "artifactName": "Fast-Renamer-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "Fast-Renamer-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Fast-Renamer-Portable-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@fast-renamer/rename-engine": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vite-plugin-electron": "^1.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14"
}
